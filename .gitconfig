[user]
	name = Sophie Katz
	email = sophie@sophiekatz.us

[core]
    sshCommand = ssh -i ~/.ssh/id_ed25519_personal

[includeIf "gitdir:~/Code/karaconnect/"]
    path = ~/.gitconfig-karaconnect

[diff]
    tool = code

[difftool "code"]
    cmd = code --wait --reuse-window --diff $LOCAL $REMOTE

[url "git@github.com:"]
      insteadOf = https://github.com/
